# RightClicks — Apache .htaccess
# Place this file in the same folder as index.html (the dist/ build output root)

# ────────────────────────────────────────────────────────────────────────
# React Router (SPA) — redirect all unknown routes to index.html
# ────────────────────────────────────────────────────────────────────────
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  RewriteRule ^ index.html [L]
</IfModule>

# ────────────────────────────────────────────────────────────────────────
# VIDEO — byte-range streaming + correct MIME type
# ────────────────────────────────────────────────────────────────────────
<IfModule mod_headers.c>
  <FilesMatch "\.(mp4|webm|ogg)$">
    Header set Accept-Ranges bytes
    Header set Cache-Control "public, max-age=2592000"
    Header set X-Content-Type-Options "nosniff"
  </FilesMatch>
</IfModule>

<IfModule mod_mime.c>
  AddType video/mp4 .mp4
  AddType video/webm .webm
</IfModule>

# ────────────────────────────────────────────────────────────────────────
# IMAGES — aggressive caching + correct MIME types
# ────────────────────────────────────────────────────────────────────────
<IfModule mod_headers.c>
  <FilesMatch "\.(png|jpg|jpeg|webp|gif|svg|ico)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
</IfModule>

<IfModule mod_mime.c>
  AddType image/webp .webp
  AddType image/svg+xml .svg
  AddType image/x-icon .ico
</IfModule>

# ────────────────────────────────────────────────────────────────────────
# GZIP compression — reduces transfer size for text-based files
# Images and videos are already compressed formats, so excluding them
# ────────────────────────────────────────────────────────────────────────
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html
  AddOutputFilterByType DEFLATE text/css
  AddOutputFilterByType DEFLATE text/javascript
  AddOutputFilterByType DEFLATE application/javascript
  AddOutputFilterByType DEFLATE application/json
  AddOutputFilterByType DEFLATE image/svg+xml

  # Do NOT compress already-compressed formats — wastes CPU with no benefit
  SetEnvIfNoCase Request_URI \.(?:gif|jpg|jpeg|png|webp|mp4|webm)$ no-gzip dont-vary
</IfModule>

# ────────────────────────────────────────────────────────────────────────
# HTML — never cache index.html so users always get the latest build
# ────────────────────────────────────────────────────────────────────────
<IfModule mod_headers.c>
  <FilesMatch "index\.html$">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
    Header set Pragma "no-cache"
    Header set Expires "0"
  </FilesMatch>
</IfModule>

# ────────────────────────────────────────────────────────────────────────
# JS / CSS — long cache (Vite hashes filenames so safe to cache forever)
# ────────────────────────────────────────────────────────────────────────
<IfModule mod_headers.c>
  <FilesMatch "\.(js|css)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
</IfModule>

# ────────────────────────────────────────────────────────────────────────
# Keep-Alive — reuses the same TCP connection for multiple requests
# instead of opening a new connection per file (speeds up page load)
# ────────────────────────────────────────────────────────────────────────
<IfModule mod_headers.c>
  Header set Connection keep-alive
</IfModule>

# ────────────────────────────────────────────────────────────────────────
# Security headers
# ────────────────────────────────────────────────────────────────────────
<IfModule mod_headers.c>
  Header set X-Content-Type-Options "nosniff"
  Header set X-Frame-Options "SAMEORIGIN"
  Header set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>
